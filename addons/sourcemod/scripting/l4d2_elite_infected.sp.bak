/**
 * ============================================================================
 *  l4d2_elite_infected.sp
 *  "Elite Special Infected" for Left 4 Dead 2
 *
 *  Requires: SourceMod 1.11+, SDKHooks extension (bundled with SM)
 *
 *  Features:
 *    - Each SI spawn has a configurable % chance to become "Elite"
 *    - Elite SI receive bonus HP (base HP * multiplier)
 *    - Elite SI are tinted a vivid colour (one per class)
 *    - All players are notified via chat when an Elite spawns
 *    - The killing survivor receives bonus temporary health
 *    - A personal env_instructor_hint is displayed to the killer
 *
 *  Installation:
 *    1. Place this file in addons/sourcemod/scripting/
 *    2. Compile with spcomp l4d2_elite_infected.sp
 *    3. Place the compiled .smx in addons/sourcemod/plugins/
 *    4. Make sure "gameinstructor_enable 1" is set on your server
 *       (add to server.cfg or use sm_cvar gameinstructor_enable 1)
 *
 *  CVars (auto-generated in cfg/sourcemod/l4d2_elite_infected.cfg):
 *    l4d2_elite_infected_enable       - 0/1 toggle (default 1)
 *    l4d2_elite_infected_chance       - 0-100 spawn chance (default 25)
 *    l4d2_elite_infected_hp_mult      - HP multiplier (default 2.5)
 *    l4d2_elite_infected_bonus_hp     - Temp HP reward for killer (default 30)
 *    l4d2_elite_infected_hint_time    - Seconds to show instructor hint (default 6)
 *
 * ============================================================================
 */

#pragma semicolon 1
#pragma newdecls required

#include <sourcemod>
#include <sdktools>
#include <sdkhooks>

// ── Plugin metadata ──────────────────────────────────────────────────────────
#define PLUGIN_VERSION  "1.0.0"
#define PLUGIN_TAG      "[Elite SI]"

// ── Team constants ────────────────────────────────────────────────────────────
#define TEAM_SURVIVOR   2
#define TEAM_INFECTED   3

// ── L4D2 Zombie class IDs (GetEntProp "m_zombieClass") ────────────────────────
#define ZC_SMOKER       1
#define ZC_BOOMER       2
#define ZC_HUNTER       3
#define ZC_SPITTER      4
#define ZC_JOCKEY       5
#define ZC_CHARGER      6
#define ZC_TANK         8   // Tanks are excluded from elite logic

// ── Per-client tracking ───────────────────────────────────────────────────────
bool    g_bIsElite[MAXPLAYERS + 1];   // true if this SI client is elite

// ── ConVar handles ────────────────────────────────────────────────────────────
ConVar  g_cvEnable;
ConVar  g_cvChance;
ConVar  g_cvHpMult;
ConVar  g_cvBonusHp;
ConVar  g_cvHintTime;

// ── Elite colour table: { R, G, B } per zombie class index (0-based = ZC-1) ──
// Smoker=purple, Boomer=lime, Hunter=cyan, Spitter=orange, Jockey=yellow, Charger=red
static const int ELITE_COLORS[6][3] =
{
    { 180,   0, 255 },   // Smoker  – vivid purple
    {   0, 255,  80 },   // Boomer  – bright lime
    {   0, 220, 255 },   // Hunter  – electric cyan
    { 255, 140,   0 },   // Spitter – orange
    { 255, 255,   0 },   // Jockey  – yellow
    { 255,  30,  30 }    // Charger – red
};

// ── Human-readable class names ────────────────────────────────────────────────
static const char SI_NAMES[7][] =
{
    "",         // index 0 unused
    "Smoker",
    "Boomer",
    "Hunter",
    "Spitter",
    "Jockey",
    "Charger"
};

// ── Default HP values per class (approximate vanilla values) ──────────────────
static const int BASE_HP[7] =
{
    0,    // index 0 unused
    250,  // Smoker
    50,   // Boomer
    250,  // Hunter
    100,  // Spitter
    325,  // Jockey
    600   // Charger
};

// =============================================================================
//  Plugin info
// =============================================================================
public Plugin myinfo =
{
    name        = "L4D2 Elite Special Infected",
    author      = "Custom",
    description = "Randomly spawns buffed, coloured Elite Special Infected with kill rewards",
    version     = PLUGIN_VERSION,
    url         = ""
};

// =============================================================================
//  OnPluginStart
// =============================================================================
public void OnPluginStart()
{
    // Create console variables
    g_cvEnable   = CreateConVar("l4d2_elite_infected_enable",   "1",    "Enable/disable the Elite SI plugin. (0=Off, 1=On)",    FCVAR_NOTIFY, true, 0.0, true, 1.0);
    g_cvChance   = CreateConVar("l4d2_elite_infected_chance",   "25",   "Percent chance (0-100) for a special infected to spawn as Elite.", FCVAR_NOTIFY, true, 0.0, true, 100.0);
    g_cvHpMult   = CreateConVar("l4d2_elite_infected_hp_mult",  "2.5",  "HP multiplier applied to the Elite SI on top of base HP.",  FCVAR_NOTIFY, true, 1.0, true, 20.0);
    g_cvBonusHp  = CreateConVar("l4d2_elite_infected_bonus_hp", "30",   "Temporary HP awarded to the survivor who kills an Elite SI.", FCVAR_NOTIFY, true, 0.0, true, 500.0);
    g_cvHintTime = CreateConVar("l4d2_elite_infected_hint_time","6",    "Seconds the instructor hint is shown to the killing survivor.", FCVAR_NOTIFY, true, 1.0, true, 30.0);

    // Auto-generate config file
    AutoExecConfig(true, "l4d2_elite_infected");

    // Game events
    HookEvent("player_spawn",  Event_PlayerSpawn,  EventHookMode_Post);
    HookEvent("player_death",  Event_PlayerDeath,  EventHookMode_Pre);

    // Reset tracking on map change / round end
    HookEvent("round_end",   Event_RoundReset, EventHookMode_Post);
    HookEvent("map_transition", Event_RoundReset, EventHookMode_Post);

    CreateConVar("l4d2_elite_infected_version", PLUGIN_VERSION, "Elite SI plugin version", FCVAR_NOTIFY | FCVAR_DONTRECORD);

    PrintToServer("%s Plugin loaded. Version %s", PLUGIN_TAG, PLUGIN_VERSION);
}

// =============================================================================
//  OnClientDisconnect – clean up state
// =============================================================================
public void OnClientDisconnect(int client)
{
    g_bIsElite[client] = false;
}

// =============================================================================
//  Event_RoundReset – clear all elite flags between rounds
// =============================================================================
public Action Event_RoundReset(Event event, const char[] name, bool dontBroadcast)
{
    for (int i = 1; i <= MaxClients; i++)
        g_bIsElite[i] = false;

    return Plugin_Continue;
}

// =============================================================================
//  Event_PlayerSpawn – decide whether this SI becomes elite
// =============================================================================
public Action Event_PlayerSpawn(Event event, const char[] name, bool dontBroadcast)
{
    if (!g_cvEnable.BoolValue)
        return Plugin_Continue;

    int client = GetClientOfUserId(event.GetInt("userid"));

    // Validate: must be an in-game infected bot/player
    if (!IsValidClient(client))
        return Plugin_Continue;

    if (GetClientTeam(client) != TEAM_INFECTED)
        return Plugin_Continue;

    // A short delay lets the engine finish spawning the entity so
    // SetEntityHealth and colour calls are reliable.
    CreateTimer(0.15, Timer_ProcessSpawn, GetClientUserId(client), TIMER_FLAG_NO_MAPCHANGE);

    return Plugin_Continue;
}

// =============================================================================
//  Timer_ProcessSpawn – safely runs after the entity is fully spawned
// =============================================================================
public Action Timer_ProcessSpawn(Handle timer, int userid)
{
    int client = GetClientOfUserId(userid);
    if (!IsValidClient(client) || !IsPlayerAlive(client))
        return Plugin_Stop;

    if (GetClientTeam(client) != TEAM_INFECTED)
        return Plugin_Stop;

    int zClass = GetEntProp(client, Prop_Send, "m_zombieClass");

    // Exclude Tank (class 8) from elite logic – tanks are powerful enough!
    if (zClass == ZC_TANK || zClass < ZC_SMOKER || zClass > ZC_CHARGER)
        return Plugin_Stop;

    // Roll for elite status
    int roll = GetRandomInt(1, 100);
    if (roll > g_cvChance.IntValue)
        return Plugin_Stop;

    // ── Mark as elite ────────────────────────────────────────────────────────
    g_bIsElite[client] = true;

    // ── Set boosted HP ───────────────────────────────────────────────────────
    int baseHp  = BASE_HP[zClass];
    int eliteHp = RoundToFloor(float(baseHp) * g_cvHpMult.FloatValue);
    SetEntityHealth(client, eliteHp);

    // ── Apply colour tint ─────────────────────────────────────────────────────
    int colorIdx = zClass - 1; // zClass starts at 1; array is 0-based
    SetEntityRenderMode(client, RENDER_TRANSCOLOR);
    SetEntityRenderColor(client,
        ELITE_COLORS[colorIdx][0],
        ELITE_COLORS[colorIdx][1],
        ELITE_COLORS[colorIdx][2],
        255);

    // ── Announce to all players ───────────────────────────────────────────────
    char className[32];
    strcopy(className, sizeof(className), SI_NAMES[zClass]);

    // Build a player name string (bots show their bot name too)
    char siName[MAX_NAME_LENGTH];
    GetClientName(client, siName, sizeof(siName));

    // Broadcast to everyone via PrintToChatAll with coloured formatting
    PrintToChatAll("%s \x04⚠ ELITE %s \x01has spawned! \x05(%d HP\x01) \x04Kill it for bonus health!",
        PLUGIN_TAG,
        className,
        eliteHp);

    return Plugin_Stop;
}

// =============================================================================
//  Event_PlayerDeath – reward the killer if victim was an elite SI
// =============================================================================
public Action Event_PlayerDeath(Event event, const char[] name, bool dontBroadcast)
{
    if (!g_cvEnable.BoolValue)
        return Plugin_Continue;

    int victim  = GetClientOfUserId(event.GetInt("userid"));
    int attacker = GetClientOfUserId(event.GetInt("attacker"));

    // Victim must be a valid elite infected
    if (!IsValidClient(victim) || !g_bIsElite[victim])
        return Plugin_Continue;

    if (GetClientTeam(victim) != TEAM_INFECTED)
        return Plugin_Continue;

    // Clear elite flag immediately
    g_bIsElite[victim] = false;

    // Attacker must be a valid alive survivor
    if (!IsValidClient(attacker))
        return Plugin_Continue;

    if (GetClientTeam(attacker) != TEAM_SURVIVOR)
        return Plugin_Continue;

    if (!IsPlayerAlive(attacker))
        return Plugin_Continue;

    int zClass = GetEntProp(victim, Prop_Send, "m_zombieClass");
    char className[32];
    if (zClass >= ZC_SMOKER && zClass <= ZC_CHARGER)
        strcopy(className, sizeof(className), SI_NAMES[zClass]);
    else
        strcopy(className, sizeof(className), "Special Infected");

    // ── Grant temporary (buffer) HP to attacker ───────────────────────────────
    int bonusHp  = g_cvBonusHp.IntValue;
    int currentTemp = GetCurrentTempHealth(attacker);
    int newTemp     = currentTemp + bonusHp;

    SetEntPropFloat(attacker, Prop_Send, "m_healthBuffer",     float(newTemp));
    SetEntPropFloat(attacker, Prop_Send, "m_healthBufferTime", GetGameTime());

    // ── Show instructor hint to attacker ──────────────────────────────────────
    ShowKillInstructorHint(attacker, className, bonusHp);

    return Plugin_Continue;
}

// =============================================================================
//  GetCurrentTempHealth – calculate actual remaining temp HP (accounts for decay)
// =============================================================================
stock int GetCurrentTempHealth(int client)
{
    float buffer     = GetEntPropFloat(client, Prop_Send, "m_healthBuffer");
    float bufferTime = GetEntPropFloat(client, Prop_Send, "m_healthBufferTime");

    if (buffer <= 0.0)
        return 0;

    // Temp health decays at pain_pills_decay_rate per second
    ConVar decayCvar = FindConVar("pain_pills_decay_rate");
    float decayRate  = (decayCvar != null) ? decayCvar.FloatValue : 1.0;
    float elapsed    = GetGameTime() - bufferTime;
    int   current    = RoundToCeil(buffer - (elapsed * decayRate)) - 1;

    return (current < 0) ? 0 : current;
}

// =============================================================================
//  ShowKillInstructorHint – creates an env_instructor_hint visible only to client
// =============================================================================
stock void ShowKillInstructorHint(int client, const char[] className, int bonusHp)
{
    if (!IsValidClient(client) || !IsPlayerAlive(client))
        return;

    // Build a unique targetname for this player so the hint binds to them
    char targetName[64];
    Format(targetName, sizeof(targetName), "elite_si_hint_target_%d", client);

    // Temporarily tag the player entity with this targetname
    DispatchKeyValue(client, "targetname", targetName);

    // Create the hint entity
    int hintEnt = CreateEntityByName("env_instructor_hint");
    if (hintEnt == -1)
        return; // Entity limit reached – silently skip

    // Caption text
    char caption[128];
    Format(caption, sizeof(caption), "★ Elite %s slain! +%d Temp HP", className, bonusHp);

    // Timeout string
    char timeoutStr[8];
    IntToString(g_cvHintTime.IntValue, timeoutStr, sizeof(timeoutStr));

    DispatchKeyValue(hintEnt, "hint_target",       targetName);
    DispatchKeyValue(hintEnt, "hint_timeout",      timeoutStr);
    DispatchKeyValue(hintEnt, "hint_caption",      caption);
    DispatchKeyValue(hintEnt, "hint_icon_onscreen","icon_skull");   // skull icon on HUD
    DispatchKeyValue(hintEnt, "hint_icon_offscreen","icon_skull");
    DispatchKeyValue(hintEnt, "hint_color",        "255 220 0");    // gold colour
    DispatchKeyValue(hintEnt, "hint_icon_offset",  "50");
    DispatchKeyValue(hintEnt, "hint_range",        "0");            // 0 = always visible
    DispatchKeyValue(hintEnt, "hint_binding",      "");
    DispatchKeyValue(hintEnt, "hint_static",       "1");            // No pulsing icon

    DispatchSpawn(hintEnt);

    // Show only to this specific client
    AcceptEntityInput(hintEnt, "ShowHint", client, client);

    // Self-destruct after hint timeout + 1s buffer
    float killDelay = float(g_cvHintTime.IntValue) + 1.0;
    char killDelayStr[16];
    Format(killDelayStr, sizeof(killDelayStr), "OnUser1 !self:Kill::%.1f:1", killDelay);
    SetVariantString(killDelayStr);
    AcceptEntityInput(hintEnt, "AddOutput");
    AcceptEntityInput(hintEnt, "FireUser1");
}

// =============================================================================
//  IsValidClient – utility
// =============================================================================
stock bool IsValidClient(int client)
{
    return (client > 0
        && client <= MaxClients
        && IsClientInGame(client)
        && IsValidEntity(client));
}
